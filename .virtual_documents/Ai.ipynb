def get_data(stock):
    df = yf.download(stock, interval="5m", period="5d")
    df.dropna(inplace=True)
    return df

df = get_data("TATASTEEL.NS")
df.tail()


def add_features(df):
    df = df.copy()

    # Ensure columns are 1D (very important fix)
    df['Close'] = df['Close'].squeeze()
    df['Volume'] = df['Volume'].squeeze()
    df['High'] = df['High'].squeeze()
    df['Low'] = df['Low'].squeeze()

    # Indicators
    df['rsi'] = ta.momentum.RSIIndicator(close=df['Close']).rsi()
    df['ma20'] = df['Close'].rolling(20).mean()
    df['ma50'] = df['Close'].rolling(50).mean()
    df['volume_ma'] = df['Volume'].rolling(20).mean()

    # VWAP (safe calculation)
    typical_price = (df['High'] + df['Low'] + df['Close']) / 3
    df['vwap'] = (typical_price * df['Volume']).cumsum() / df['Volume'].cumsum()

    # FINAL CLEANUP (VERY IMPORTANT)
    df = df.dropna().reset_index(drop=True)

    return df


def add_features(df):
    df = df.copy()

    # 🔥 Flatten columns (CRITICAL)
    if isinstance(df.columns, pd.MultiIndex):
        df.columns = df.columns.get_level_values(0)

    # Ensure numeric
    df['Close'] = pd.to_numeric(df['Close'], errors='coerce')
    df['Volume'] = pd.to_numeric(df['Volume'], errors='coerce')
    df['High'] = pd.to_numeric(df['High'], errors='coerce')
    df['Low'] = pd.to_numeric(df['Low'], errors='coerce')

    # Indicators
    df['rsi'] = ta.momentum.RSIIndicator(df['Close']).rsi()
    df['ma20'] = df['Close'].rolling(20).mean()
    df['ma50'] = df['Close'].rolling(50).mean()
    df['volume_ma'] = df['Volume'].rolling(20).mean()

    # VWAP
    typical_price = (df['High'] + df['Low'] + df['Close']) / 3
    df['vwap'] = (typical_price * df['Volume']).cumsum() / df['Volume'].cumsum()

    return df



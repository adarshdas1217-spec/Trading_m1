def create_target(df):
    df = df.copy()

    # Flatten columns if needed
    if isinstance(df.columns, pd.MultiIndex):
        df.columns = df.columns.get_level_values(0)

    # Force Close to 1D
    close = pd.Series(df['Close'].values, index=df.index)

    # Future price
    future_price = close.shift(-3)

    # Target
    df['target'] = (future_price > close).astype(int)

    return df


print(df.columns)


def get_signal(model, row):
    row = row.fillna(0)

    prob = model.predict_proba(row.values.reshape(1, -1))[0][1]

    if prob > 0.65:
        return "BUY", prob
    elif prob < 0.35:
        return "SELL", prob
    else:
        return "HOLD", prob


def strategy_filter(df):
    latest = df.iloc[-1]

    conditions = [
        latest['Close'] > latest['vwap'],           # trend
        latest['Volume'] > latest['volume_ma'],     # volume spike
        latest['Close'] > df['High'].rolling(20).max().iloc[-1]  # breakout
    ]

    return all(conditions)


# Strategy filter
def strategy_filter(df):
    latest = df.iloc[-1]

    conditions = [
        latest['Close'] > latest['vwap'],
        latest['Volume'] > latest['volume_ma'],
        latest['Close'] > df['High'].rolling(20).max().iloc[-1]
    ]

    return all(conditions)


# Trade decision
def generate_trade(df, model):
    latest = df.iloc[-1]

    features = latest[['rsi','ma20','ma50','volume_ma']].fillna(0)

    prob = model.predict_proba(features.values.reshape(1, -1))[0][1]

    if prob > 0.65 and strategy_filter(df):
        return "BUY", prob

    elif prob < 0.35:
        return "SELL", prob

    return "NO TRADE", prob


